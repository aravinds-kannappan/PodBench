# Inference provider — set ONE to execute live agent runs from the dashboard,
# the worker, and the backfill script. OpenRouter takes priority when both set.

# OpenRouter (OpenAI-compatible). Anthropic model ids resolve to OpenRouter slugs
# automatically (claude-opus-4-8 -> anthropic/claude-opus-4.8).
OPENROUTER_API_KEY=

# Native Anthropic. Read more: https://platform.claude.com/
ANTHROPIC_API_KEY=

# Canonical policy model id. Defaults to claude-opus-4-8.
PODBENCH_MODEL=claude-opus-4-8

# Effort hint for the policy: low | medium | high. Defaults to medium.
PODBENCH_EFFORT=medium

# Optional queue backend for the worker (not needed for the dashboard).
# Leave REDIS_URL empty to run the worker against the in-process queue.
REDIS_URL=
PODBENCH_QUEUE=podbench:tasks

# Optional: pin the synthetic clock the SQL environment uses for date math.
PODBENCH_ENV_NOW=2026-06-15
