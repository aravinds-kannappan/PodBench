# podbench worker image. Runs the agent episode loop against the deterministic
# environment and reports per-run token metering as structured logs.
FROM node:22-bookworm-slim AS base
WORKDIR /app

# Install dependencies against the lockfile for reproducible images.
COPY package.json package-lock.json* ./
RUN npm ci --omit=optional || npm install

# Application code. The worker shares lib/ with the dashboard so the run path is
# identical in both surfaces.
COPY tsconfig.json ./
COPY lib ./lib
COPY infra/worker ./infra/worker

ENV NODE_ENV=production
ENV PODBENCH_MODEL=claude-opus-4-8
ENV PODBENCH_EFFORT=medium

# Run TypeScript directly with tsx; no build step needed for the worker.
ENTRYPOINT ["npx", "tsx", "infra/worker/worker.ts"]
